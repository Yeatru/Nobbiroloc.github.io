page {
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1e293b;
  line-height: 1.6;
  min-height: 100vh;
}

.container {
  padding: 0;
  min-height: 100vh;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.card-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.5rpx;
}

.card-header-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  line-height: 1.5;
}

.card-body {
  padding: 28rpx 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.btn-secondary {
  background-color: #f8fafc;
  color: #64748b;
  border: 2rpx solid #e2e8f0;
  border-radius: 48rpx;
  padding: 28rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background-color: #f1f5f9;
  border-color: #cbd5e1;
}

.btn-outline {
  background-color: transparent;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 48rpx;
  padding: 26rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.btn-outline:active {
  background-color: rgba(74, 144, 217, 0.08);
}

.input-field {
  background-color: #f8fafc;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  color: #1e293b;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
  width: 100%;
  min-height: 96rpx;
  line-height: 1.5;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #4A90D9;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  letter-spacing: -0.5rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.text-gray {
  color: #94a3b8;
}

.text-primary {
  color: #4A90D9;
}

.text-success {
  color: #22c55e;
}

.text-warning {
  color: #f59e0b;
}

.text-danger {
  color: #ef4444;
}

.font-bold {
  font-weight: 700;
}

.mt-10 { margin-top: 10rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-16 { padding: 16rpx; }
.p-20 { padding: 20rpx; }
.p-24 { padding: 24rpx; }
.p-30 { padding: 30rpx; }

.safe-bottom {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fadeIn {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fadeInUp {
  animation: fadeInUp 0.5s ease-out;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.animate-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.tag-success {
  background-color: rgba(34, 197, 94, 0.1);
  color: #22c55e;
}

.tag-warning {
  background-color: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.tag-danger {
  background-color: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.skeleton {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.divider {
  height: 16rpx;
  background-color: #f8fafc;
  margin: 0;
}

.glow-effect {
  box-shadow: 0 0 30rpx rgba(74, 144, 217, 0.15);
}
