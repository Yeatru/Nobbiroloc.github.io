page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.card-header-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.card-body {
  padding: 24rpx 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #666666;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.btn-secondary:active {
  background-color: #eeeeee;
}

.btn-outline {
  background-color: transparent;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 40rpx;
  padding: 22rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.btn-outline:active {
  background-color: rgba(74, 144, 217, 0.1);
}

.input-field {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  width: 100%;
}

.input-field:focus {
  border-color: #4A90D9;
  background-color: #ffffff;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background-color: #4A90D9;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.text-gray {
  color: #999999;
}

.text-primary {
  color: #4A90D9;
}

.text-success {
  color: #27AE60;
}

.text-warning {
  color: #F39C12;
}

.text-danger {
  color: #E74C3C;
}

.font-bold {
  font-weight: 600;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

.safe-bottom {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fadeIn {
  animation: fadeIn 0.3s ease-out;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-pulse {
  animation: pulse 1.5s ease-in-out infinite;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-primary {
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.tag-success {
  background-color: rgba(39, 174, 96, 0.1);
  color: #27AE60;
}

.tag-warning {
  background-color: rgba(243, 156, 18, 0.1);
  color: #F39C12;
}

.tag-danger {
  background-color: rgba(231, 76, 60, 0.1);
  color: #E74C3C;
}