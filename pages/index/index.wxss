.search-bar {
  padding: 20rpx 0;
  margin-bottom: 10rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.section {
  margin-bottom: 30rpx;
}

.hot-tools-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.hot-tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.hot-tool-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.icon-text {
  font-size: 36rpx;
  font-weight: 600;
}

.hot-tool-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.category-icon-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.category-desc {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-arrow {
  font-size: 36rpx;
  color: #cccccc;
  margin-left: 16rpx;
}

.category-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tool-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.tool-tag:active {
  background-color: #e8e8e8;
  transform: scale(0.96);
}

.welfare-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe6cc 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.welfare-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.welfare-text {
  flex: 1;
}

.welfare-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e67300;
  margin-bottom: 4rpx;
}

.welfare-desc {
  font-size: 22rpx;
  color: #cc7a00;
}

.welfare-arrow {
  font-size: 36rpx;
  color: #e67300;
}

.footer-banner {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.banner-placeholder {
  background-color: #f0f0f0;
  border-radius: 12rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  font-size: 24rpx;
  color: #999999;
}

.welfare-modal {
  width: 620rpx;
}

.welfare-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
}

.welfare-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.welfare-modal-close {
  font-size: 44rpx;
  color: #999999;
  line-height: 1;
}

.welfare-modal-body {
  padding: 0 32rpx 32rpx;
}

.welfare-modal-desc {
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 30rpx;
}

.qr-code-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.qr-code-placeholder {
  flex: 1;
  aspect-ratio: 1;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #e0e0e0;
}

.qr-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.qr-text {
  font-size: 22rpx;
  color: #999999;
}

.welfare-modal-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}