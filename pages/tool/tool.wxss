.tool-page {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.tool-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.tool-tab-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.tool-tab-item:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.tool-tab-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.tool-tab-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.tool-subtabs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.tool-subtab-item {
  padding: 16rpx 28rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.tool-subtab-item.active {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  font-weight: 500;
}

.input-section {
  margin-bottom: 24rpx;
}

.input-tip {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.textarea {
  min-height: 200rpx;
  resize: none;
}

.input-desc {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.image-upload-area {
  background-color: #f8f8f8;
  border: 2rpx dashed #e0e0e0;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.upload-desc {
  font-size: 22rpx;
  color: #999999;
}

.disclaimer {
  display: flex;
  align-items: flex-start;
  background-color: #fff9e6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-sizing: border-box;
}

.disclaimer-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #996600;
  line-height: 1.6;
  flex: 1;
  word-break: break-all;
}

.zodiac-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.zodiac-item {
  padding: 20rpx 10rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.zodiac-item.active {
  background-color: rgba(74, 144, 217, 0.1);
  border-color: #4A90D9;
  color: #4A90D9;
  font-weight: 500;
}

.input-row {
  display: flex;
  gap: 20rpx;
}

.input-half {
  flex: 1;
}

.textarea-large {
  min-height: 300rpx;
  resize: none;
}

.picker-field {
  display: flex;
  align-items: center;
  color: #333333;
}

.picker-field:empty::after {
  content: attr(placeholder);
  color: #999999;
}

.calc-type-switch {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.calc-type-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 34rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.calc-type-item.active {
  background-color: #ffffff;
  color: #4A90D9;
  font-weight: 500;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}