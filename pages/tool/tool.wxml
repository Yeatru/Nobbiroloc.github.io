<view class="tool-page">
  <view class="tool-tabs" wx:if="{{!currentTool}}">
    <view
      class="tool-tab-item"
      wx:for="{{toolList}}"
      wx:key="id"
      data-tool-id="{{item.id}}"
      bindtap="onToolSelect"
    >
      <view class="tool-tab-icon">{{item.name.charAt(0)}}</view>
      <view class="tool-tab-name">{{item.name}}</view>
    </view>
  </view>

  <view class="tool-content" wx:if="{{currentTool}}">
    <view class="tool-subtabs">
      <view
        class="tool-subtab-item {{toolId === item.id ? 'active' : ''}}"
        wx:for="{{toolList}}"
        wx:key="id"
        data-tool-id="{{item.id}}"
        bindtap="onToolSelect"
      >
        {{item.name}}
      </view>
    </view>

    <view class="input-section card">
      <view class="card-header">
        <view class="card-header-title">{{toolName}}</view>
      </view>
      <view class="card-body">
        <block wx:if="{{categoryId === 'ai-copy'}}">
          <block wx:if="{{toolId === 'name-generator'}}">
            <view class="input-tip">请输入姓氏或关键词（可选）</view>
            <input
              class="input-field"
              placeholder="请输入姓氏，如：张、王"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
          </block>
          <block wx:elif="{{toolId === 'horoscope'}}">
            <view class="input-tip">请选择你的星座</view>
            <view class="zodiac-grid">
              <view
                class="zodiac-item {{selectedOptions.zodiac === item ? 'active' : ''}}"
                wx:for="{{['白羊座','金牛座','双子座','巨蟹座','狮子座','处女座','天秤座','天蝎座','射手座','摩羯座','水瓶座','双鱼座']}}"
                wx:key="*this"
                data-option-key="zodiac"
                data-option-value="{{item}}"
                bindtap="onOptionSelect"
              >
                {{item}}
              </view>
            </view>
          </block>
          <block wx:elif="{{toolId === 'acrostic-poem'}}">
            <view class="input-tip">请输入藏头文字（2-8个汉字）</view>
            <input
              class="input-field"
              placeholder="如：生日快乐、万事如意"
              value="{{inputValue}}"
              bindinput="onInputChange"
              maxlength="8"
            />
            <view class="input-desc">输入的每个字将作为诗句的第一个字</view>
          </block>
          <block wx:else>
            <view class="input-tip">请输入关键词或需求描述</view>
            <textarea
              class="input-field textarea"
              placeholder="请输入关键词或需求描述，如：周末出游、产品推广..."
              value="{{inputValue}}"
              bindinput="onInputChange"
              maxlength="500"
              auto-height
            />
          </block>
        </block>

        <block wx:if="{{categoryId === 'decor-calc'}}">
          <block wx:if="{{toolId === 'tile'}}">
            <view class="input-tip">请输入房间面积（平方米）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入面积，如：20"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按600×600mm规格瓷砖计算</view>
          </block>
          <block wx:elif="{{toolId === 'paint'}}">
            <view class="input-tip">请输入墙面面积（平方米）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入墙面面积"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按涂刷2遍计算</view>
          </block>
          <block wx:elif="{{toolId === 'water-electric'}}">
            <view class="input-tip">请输入房屋建筑面积（平方米）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入建筑面积"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按每平米120元标准估算</view>
          </block>
          <block wx:elif="{{toolId === 'public-area'}}">
            <view class="input-tip">请输入房屋建筑面积（平方米）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入建筑面积"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按20%公摊率估算</view>
          </block>
        </block>

        <block wx:if="{{categoryId === 'finance-calc'}}">
          <block wx:if="{{toolId === 'tax'}}">
            <view class="input-tip">请输入月工资收入（元）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入月工资"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">未包含专项附加扣除</view>
          </block>
          <block wx:elif="{{toolId === 'mortgage'}}">
            <view class="input-tip">请输入贷款金额（万元）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入贷款金额"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按30年等额本息、4.2%利率计算</view>
          </block>
          <block wx:elif="{{toolId === 'prepay-mortgage'}}">
            <view class="input-tip">贷款信息</view>
            <view class="input-row">
              <input
                class="input-field input-half"
                type="digit"
                placeholder="贷款金额(万)"
                value="{{selectedOptions.loanAmount}}"
                data-field="loanAmount"
                bindinput="onHealthInputChange"
              />
              <input
                class="input-field input-half"
                type="digit"
                placeholder="贷款年限"
                value="{{selectedOptions.years}}"
                data-field="years"
                bindinput="onHealthInputChange"
              />
            </view>
            <view class="input-row">
              <input
                class="input-field input-half"
                type="digit"
                placeholder="年利率(%)"
                value="{{selectedOptions.rate}}"
                data-field="rate"
                bindinput="onHealthInputChange"
              />
              <input
                class="input-field input-half"
                type="digit"
                placeholder="已还月数"
                value="{{selectedOptions.paidMonths}}"
                data-field="paidMonths"
                bindinput="onHealthInputChange"
              />
            </view>
            <view class="input-tip mt-20">提前还款信息</view>
            <input
              class="input-field"
              type="digit"
              placeholder="提前还款金额（万元）"
              value="{{selectedOptions.prepayAmount}}"
              data-field="prepayAmount"
              bindinput="onHealthInputChange"
            />
            <view class="input-desc">计算提前还款可节省的利息和时间</view>
          </block>
          <block wx:elif="{{toolId === 'fuel-calc'}}">
            <view class="input-tip">行程信息</view>
            <input
              class="input-field"
              type="digit"
              placeholder="行驶里程（公里）"
              value="{{selectedOptions.distance}}"
              data-field="distance"
              bindinput="onHealthInputChange"
            />
            <view class="input-row mt-20">
              <input
                class="input-field input-half"
                type="digit"
                placeholder="油价(元/升)"
                value="{{selectedOptions.fuelPrice}}"
                data-field="fuelPrice"
                bindinput="onHealthInputChange"
              />
              <input
                class="input-field input-half"
                type="digit"
                placeholder="油耗(L/100km)"
                value="{{selectedOptions.fuelConsumption}}"
                data-field="fuelConsumption"
                bindinput="onHealthInputChange"
              />
            </view>
            <view class="input-desc">计算油费开销和每公里成本</view>
          </block>
          <block wx:elif="{{toolId === 'fund'}}">
            <view class="input-tip">请输入每月定投金额（元）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入每月定投金额"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">按10年、年化8%收益率估算</view>
          </block>
          <block wx:elif="{{toolId === 'exchange'}}">
            <view class="input-tip">请输入人民币金额（元）</view>
            <input
              class="input-field"
              type="digit"
              placeholder="请输入金额"
              value="{{inputValue}}"
              bindinput="onInputChange"
            />
            <view class="input-desc">汇率为模拟参考值</view>
          </block>
        </block>

        <block wx:if="{{categoryId === 'health-tool'}}">
          <block wx:if="{{toolId === 'bmi'}}">
            <view class="input-tip">身体数据</view>
            <view class="input-row">
              <input
                class="input-field input-half"
                type="digit"
                placeholder="身高(cm)"
                value="{{selectedOptions.height}}"
                data-field="height"
                bindinput="onHealthInputChange"
              />
              <input
                class="input-field input-half"
                type="digit"
                placeholder="体重(kg)"
                value="{{selectedOptions.weight}}"
                data-field="weight"
                bindinput="onHealthInputChange"
              />
            </view>
            <view class="input-desc">BMI = 体重(kg) ÷ 身高(m)²</view>
          </block>
        </block>

        <block wx:if="{{categoryId === 'efficiency-tool'}}">
          <block wx:if="{{toolId === 'word-count'}}">
            <view class="input-tip">请输入要统计的文字</view>
            <textarea
              class="input-field textarea-large"
              placeholder="粘贴或输入文字内容..."
              value="{{inputValue}}"
              bindinput="onInputChange"
              auto-height
              maxlength="10000"
            />
            <view class="input-desc">支持统计字数、字符数、行数、段落数</view>
          </block>
          <block wx:elif="{{toolId === 'date-calc'}}">
            <view class="calc-type-switch">
              <view
                class="calc-type-item {{selectedOptions.calcType !== 'add' ? 'active' : ''}}"
                bindtap="onCalcTypeChange"
                data-value="diff"
              >
                日期差
              </view>
              <view
                class="calc-type-item {{selectedOptions.calcType === 'add' ? 'active' : ''}}"
                bindtap="onCalcTypeChange"
                data-value="add"
              >
                日期计算
              </view>
            </view>

            <block wx:if="{{selectedOptions.calcType !== 'add'}}">
              <view class="input-tip">选择两个日期</view>
              <picker mode="date" value="{{selectedOptions.date1}}" data-field="date1" bindchange="onDateChange">
                <view class="input-field picker-field">
                  {{selectedOptions.date1 || '选择开始日期'}}
                </view>
              </picker>
              <picker mode="date" value="{{selectedOptions.date2}}" data-field="date2" bindchange="onDateChange">
                <view class="input-field picker-field mt-20">
                  {{selectedOptions.date2 || '选择结束日期'}}
                </view>
              </picker>
              <view class="input-desc">计算两个日期之间相差的天数</view>
            </block>
            <block wx:else>
              <view class="input-tip">起始日期</view>
              <picker mode="date" value="{{selectedOptions.date1}}" data-field="date1" bindchange="onDateChange">
                <view class="input-field picker-field">
                  {{selectedOptions.date1 || '选择起始日期'}}
                </view>
              </picker>
              <view class="input-tip mt-20">加减天数</view>
              <input
                class="input-field"
                type="number"
                placeholder="输入天数（正数加，负数减）"
                value="{{inputValue}}"
                bindinput="onInputChange"
              />
              <view class="input-desc">计算N天前/后的日期</view>
            </block>
          </block>
        </block>

        <block wx:if="{{categoryId === 'ai-image'}}">
          <view class="image-upload-area">
            <view class="upload-icon">📷</view>
            <view class="upload-text">点击上传图片</view>
            <view class="upload-desc">支持JPG、PNG格式</view>
          </view>
        </block>

        <button
          class="btn-primary mt-30"
          bindtap="onProcess"
          loading="{{isProcessing}}"
          disabled="{{isProcessing}}"
        >
          {{categoryId === 'ai-image' ? '上传并处理' : '立即生成'}}
        </button>
      </view>
    </view>

    <view class="disclaimer" wx:if="{{disclaimer}}">
      <text class="disclaimer-icon">⚠️</text>
      <text class="disclaimer-text">{{disclaimer}}</text>
    </view>
  </view>
</view><view class="tool-page">
