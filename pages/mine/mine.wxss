.mine-page {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

.user-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.unlock-status {
  margin-bottom: 24rpx;
}

.unlock-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.unlock-info {
  display: flex;
  gap: 20rpx;
}

.unlock-item {
  flex: 1;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.unlock-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.unlock-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
}

.unlock-value.active {
  color: #27AE60;
}

.section {
  margin-bottom: 24rpx;
}

.records-card .record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.records-card .record-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.records-card .record-item:first-child {
  padding-top: 0;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background-color: #f0f7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.record-category {
  font-size: 22rpx;
  color: #999999;
}

.record-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.empty-card {
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999999;
}

.menu-card .menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-card .menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-card .menu-item:first-child {
  padding-top: 0;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-info {
  flex: 1;
}

.menu-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.welfare-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe6cc 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.welfare-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.welfare-text {
  flex: 1;
}

.welfare-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e67300;
  margin-bottom: 4rpx;
}

.welfare-desc {
  font-size: 22rpx;
  color: #cc7a00;
}

.welfare-arrow {
  font-size: 36rpx;
  color: #e67300;
}

.footer-banner {
  margin-top: 20rpx;
}

.banner-placeholder {
  background-color: #f0f0f0;
  border-radius: 12rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  font-size: 24rpx;
  color: #999999;
}

.welfare-modal {
  width: 620rpx;
}

.welfare-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
}

.welfare-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.welfare-modal-close {
  font-size: 44rpx;
  color: #999999;
  line-height: 1;
}

.welfare-modal-body {
  padding: 0 32rpx 32rpx;
}

.welfare-modal-desc {
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 30rpx;
}

.qr-code-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.qr-code-placeholder {
  flex: 1;
  aspect-ratio: 1;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #e0e0e0;
}

.qr-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.qr-text {
  font-size: 22rpx;
  color: #999999;
}

.welfare-modal-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}