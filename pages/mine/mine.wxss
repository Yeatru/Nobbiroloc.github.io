.mine-page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 140rpx;
}

.user-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.unlock-status {
  margin-bottom: 28rpx;
}

.unlock-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.unlock-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.unlock-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.unlock-item:active {
  transform: scale(0.98);
}

.unlock-label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.unlock-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
}

.unlock-value.active {
  color: #22c55e;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.records-card .record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  transition: all 0.2s ease;
}

.records-card .record-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.records-card .record-item:first-child {
  padding-top: 0;
}

.records-card .record-item:active {
  background-color: #f8fafc;
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.record-category {
  font-size: 24rpx;
  color: #94a3b8;
}

.record-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
}

.empty-card {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
}

.menu-card .menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  transition: all 0.2s ease;
}

.menu-card .menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-card .menu-item:first-child {
  padding-top: 0;
}

.menu-card .menu-item:active {
  background-color: #f8fafc;
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 56rpx;
  text-align: center;
}

.menu-info {
  flex: 1;
}

.menu-name {
  font-size: 30rpx;
  color: #1e293b;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
}

.welfare-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe6cc 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(251, 191, 36, 0.2);
  transition: all 0.3s ease;
}

.welfare-entry:active {
  transform: scale(0.98);
}

.welfare-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.welfare-text {
  flex: 1;
}

.welfare-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ea580c;
  margin-bottom: 8rpx;
}

.welfare-desc {
  font-size: 24rpx;
  color: #c2410c;
}

.welfare-arrow {
  font-size: 40rpx;
  color: #ea580c;
}

.footer-banner {
  margin-top: 24rpx;
}

.banner-placeholder {
  background-color: #f1f5f9;
  border-radius: 16rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.welfare-modal {
  width: 640rpx;
}

.welfare-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 36rpx 24rpx;
}

.welfare-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
}

.welfare-modal-close {
  font-size: 48rpx;
  color: #94a3b8;
  line-height: 1;
}

.welfare-modal-body {
  padding: 0 36rpx 36rpx;
}

.welfare-modal-desc {
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 36rpx;
}

.qr-code-area {
  display: flex;
  gap: 28rpx;
  margin-bottom: 36rpx;
}

.qr-code-placeholder {
  flex: 1;
  aspect-ratio: 1;
  background-color: #ffffff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #e2e8f0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.qr-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.qr-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.welfare-modal-tip {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}